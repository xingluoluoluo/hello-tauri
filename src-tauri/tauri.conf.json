{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hello-tauri",
  "version": "0.1.0",
  "identifier": "com.zll.hello-tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "hello-tauri",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "assetProtocol": { "enable": true, "scope": ["C:\\Users\\**", "$APPDATA/**", "$APPDATA", "$TEMP/**", "**/*", "$APPDATA/dynamic-dist/**"] },
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' http://asset.localhost; img-src 'self' asset: http://asset.localhost data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' http://asset.localhost; style-src 'self' 'unsafe-inline' http://asset.localhost; connect-src 'self'; frame-src 'self' http://asset.localhost;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
